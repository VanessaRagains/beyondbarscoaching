---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms &amp; Conditions | Beyond BARS Coaching"
  description="Terms and Conditions for Beyond BARS Coaching."
>

  <section class="section">
    <div class="container content-width">
      <h1>Terms &amp; Conditions</h1>
      <div class="divider" style="margin-left: 0;"></div>

      <p class="intro">
        By using this website and participating in Beyond BARS Coaching programs, you agree to
        the following terms and conditions.
      </p>

      <h2>Use of This Website</h2>
      <p>
        This website is provided for informational purposes and to connect system-impacted women
        with coaching and community resources. You agree not to misuse this site or its content.
      </p>

      <h2>Coaching Services</h2>
      <p>
        Beyond BARS Coaching provides health and life coaching. Coaching is not therapy, medical
        advice, or legal advice. Always consult qualified professionals for medical, legal, or
        mental health concerns.
      </p>

      <h2>Donations</h2>
      <p>
        Donations made through this site support Beyond BARS Coaching, a 501(c)(3) nonprofit
        organization (EIN #33-1514564). Donations are tax-deductible to the extent allowed by law.
      </p>

      <h2>Intellectual Property</h2>
      <p>
        All content on this site — including text, images, PDFs, and program materials — is
        the property of Beyond BARS Coaching and may not be reproduced without written permission.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms? Contact us at
        <a href="mailto:Vanessa.Ragains@gmail.com">Vanessa.Ragains@gmail.com</a>
        or text <a href="sms:+16503076592">(650) 307-6592</a>.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
h1 { font-size: var(--text-4xl); margin-bottom: var(--space-4); }
h2 { font-size: var(--text-2xl); margin-top: var(--space-8); margin-bottom: var(--space-3); }
p { color: var(--color-text-light); margin-bottom: var(--space-4); }
.intro { font-size: var(--text-lg); }
</style>
