---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Statement | Beyond BARS Coaching"
  description="Privacy Statement for Beyond BARS Coaching."
>

  <section class="section">
    <div class="container content-width">
      <h1>Privacy Statement</h1>
      <div class="divider" style="margin-left: 0;"></div>

      <p class="intro">
        Beyond BARS Coaching is committed to protecting your privacy. This page explains how
        we collect and use your information.
      </p>

      <p>
        For our full Privacy Policy &amp; SMS Communication policy, please download the PDF below:
      </p>

      <a href="/downloads/privacy-policy.pdf" class="btn btn-primary" download style="margin: 1.5rem 0; display: inline-flex; align-items: center; gap: 0.5rem;">
        📄 Download Privacy Policy &amp; SMS Communication (PDF)
      </a>

      <h2>Contact</h2>
      <p>
        For privacy-related questions, contact us at
        <a href="mailto:Vanessa.Ragains@gmail.com">Vanessa.Ragains@gmail.com</a>
        or text <a href="sms:+16503076592">(650) 307-6592</a>.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
h1 { font-size: var(--text-4xl); margin-bottom: var(--space-4); }
h2 { font-size: var(--text-2xl); margin-top: var(--space-8); margin-bottom: var(--space-3); }
p { color: var(--color-text-light); margin-bottom: var(--space-4); }
.intro { font-size: var(--text-lg); }
</style>
