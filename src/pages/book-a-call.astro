---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book A Call | Beyond BARS Coaching"
  description="Schedule a call with Vanessa Ragains, founder of Beyond BARS Coaching."
>

  <section class="section-sm bg-soft text-center">
    <div class="container">
      <h1>Book A Call With Vanessa</h1>
      <p class="page-sub">Choose a time that works for you and let's connect.</p>
      <div class="divider"></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="calendar-wrap">
        <!-- Google Calendar Appointment Scheduling begin -->
        <iframe
          src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ1p2gMd6akUru_3fuAi9tUYmDN1URTSzhyMGh-M2FNEnsCtEVyHfUBdvZXrbwGxYTfzzEA5nexT?gv=true"
          style="border: 0"
          width="100%"
          height="700"
          frameborder="0"
          title="Book a call with Vanessa"
          loading="lazy"
        ></iframe>
        <!-- end Google Calendar Appointment Scheduling -->
      </div>
      <p class="calendar-note">
        Having trouble with the calendar?
        <a href="https://calendar.app.google/ugCuTyYGAxa1Rprr6" target="_blank" rel="noopener">
          Open it directly →
        </a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.page-sub { color: var(--color-text-light); font-size: var(--text-lg); margin-top: var(--space-3); }
.calendar-wrap {
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--color-brand-subtle);
}
.calendar-note {
  text-align: center;
  margin-top: var(--space-4);
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}
</style>
