---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Rebel Resources | Beyond BARS Coaching"
  description="Resources for the Sober Rebel community."
>

  <section class="section text-center">
    <div class="container">
      <h1>Rebel Resources</h1>
      <div class="divider"></div>
      <p class="coming-soon">
        The Rebel Resources store is coming soon. In the meantime, download our free resources on
        the <a href="/about#resources">About page</a>.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.coming-soon { color: var(--color-text-light); font-size: var(--text-lg); max-width: 500px; margin-inline: auto; }
</style>
