---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import VanessaImage from '../assets/vanessa-ragains.jpg';
import JessieImage from '../assets/board-jessie.jpg';
import HaileyImage from '../assets/board-hailey.jpg';
---

<BaseLayout
  title="About | Beyond BARS Coaching"
  description="Beyond BARS Coaching supports alcohol-free women—especially those who are system-impacted—in rebuilding safety, self-trust, and stability through trauma-informed coaching, nervous-system education, and community connection."
>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container text-center">
      <div class="hero-text">
        <h1>Hi Rebel! Welcome to Beyond BARS Coaching!</h1>
        <p class="hero-tagline">
          Support alcohol-free women—especially those who are system-impacted—in rebuilding safety,
          self-trust, and stability through trauma-informed coaching, nervous-system education, and
          community connection.
        </p>
        <div class="hero-links">
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSfy1H7JxP4Bt5CCJz8qJ77Eb5kz5uNmn7GHEz7FX4L98ybReg/viewform" target="_blank" rel="noopener" class="btn btn-primary">
            Fill Out Registration Form
          </a>
          <a href="/%F0%9F%92%9B-choose-your-impact" class="btn btn-secondary">💛 Choose Your Impact</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Mission ───────────────────────────────────────────────────── -->
  <section class="section bg-soft">
    <div class="container text-center">
      <div class="divider"></div>
      <h2 class="section-heading">Our Mission</h2>
      <p class="mission-statement">
        Sustainable sobriety and successful reentry are not created through willpower or punishment,
        but through <strong>structure, safety, and support.</strong>
      </p>
      <p class="mission-body">
        Beyond BARS Coaching is the framework. The Sober Rebel Club is the community. Together,
        they create a continuum of care for system-impacted women navigating major life transitions.
      </p>
    </div>
  </section>

  <!-- ── About Vanessa ─────────────────────────────────────────────── -->
  <section class="section">
    <div class="container about-vanessa">
      <div>
        <h2>👋 Hello, I'm Vanessa</h2>
        <p>
          I'm Vanessa Ragains, and I've been sober since December 9, 2020. I lived in group homes
          from ages 13–17 and experienced homelessness—experiences that shaped everything about my
          mission to help system-impacted women navigate major life transitions.
        </p>
        <p>
          As a certified Health &amp; Life Coach, Herbalist, and Registered Yoga Teacher (RYT-500),
          I bring over two decades of holistic practice to every coaching relationship. I retired
          from my Massage Therapy career and poured all of that knowledge into this work.
        </p>
        <a href="/program-details" class="btn btn-primary" style="margin-top: 1.5rem;">Learn About The Program</a>
      </div>
      <div class="about-portrait">
        <Image src={VanessaImage} alt="Vanessa Ragains" loading="lazy"></Image>
      </div>
    </div>
  </section>

  <!-- ── What You'll Learn ──────────────────────────────────────────── -->
  <section class="section bg-section">
    <div class="container text-center">
      <h2 class="section-heading">🧠 What You'll Learn</h2>
      <div class="divider"></div>
      <div class="learn-grid grid-3" style="margin-top: 2.5rem;">
        <div class="card card-body">
          <div class="learn-icon">🎯</div>
          <h3>Clarify Your Goals</h3>
          <p>Receive a personalized, step-by-step Sober Rebel Plan that integrates your education
          and career journey, while maintaining a strong, authentic LinkedIn profile that reflects
          your growth and goals.</p>
        </div>
        <div class="card card-body">
          <div class="learn-icon">🏛️</div>
          <h3>Honor the 3 Pillars</h3>
          <p>You'll build supportive goals across Nourishment, Self-Care, and Personal
          Development—the three pillars that ground our work and create sustainable progress.</p>
        </div>
        <div class="card card-body">
          <div class="learn-icon">🧘</div>
          <h3>Cultivate Healthy Mobility</h3>
          <p>Through a thoughtful blend of herbal wellness and trauma-informed yoga, you'll develop
          a mobility practice that restores movement, supports nervous-system regulation, and helps
          your body feel safer, steadier, and more resilient.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAST Method ────────────────────────────────────────────────── -->
  <section class="section" id="fast-method">
    <div class="container text-center">
      <h2 class="section-heading">🧩 The F.A.S.T. Method</h2>
      <p class="section-sub">Healing happens through safety + repetition, not pressure.</p>
      <div class="fast-grid grid-4">
        <div class="fast-card">
          <div class="fast-letter">F</div>
          <h3>Foundation</h3>
          <p>Nervous-system safety and daily rhythms that create stability.</p>
        </div>
        <div class="fast-card">
          <div class="fast-letter">A</div>
          <h3>Accountability</h3>
          <p>Supportive structure and reflective practices to keep you on track.</p>
        </div>
        <div class="fast-card">
          <div class="fast-letter">S</div>
          <h3>Support</h3>
          <p>Trauma-informed coaching and peer connection that meets you where you are.</p>
        </div>
        <div class="fast-card">
          <div class="fast-letter">T</div>
          <h3>Tools</h3>
          <p>Practical, repeatable practices you can reach for in any moment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Board Members ──────────────────────────────────────────────── -->
  <section class="section bg-soft" id="board">
    <div class="container text-center">
      <h2 class="section-heading">🤝 Our Board</h2>
      <div class="divider"></div>
      <div class="board-grid" style="margin-top: 2.5rem;">
        <div class="board-member">
          <div class="board-photo">
            <Image src={VanessaImage} alt="Vanessa Ragains" width="300" loading="lazy"></Image>
          </div>
          <h3>Vanessa Ragains</h3>
          <p class="board-title">President &amp; Founder</p>
        </div>
        <div class="board-member">
          <div class="board-photo">
            <Image src={JessieImage} alt="Jessie Keck" width="300" loading="lazy"></Image>
          </div>
          <h3>Jessie Keck</h3>
          <p class="board-title">Treasurer</p>
        </div>
        <div class="board-member">
          <div class="board-photo">
            <Image src={HaileyImage} alt="Hailey Brock" width="300" loading="lazy"></Image>
          </div>
          <h3>Hailey Brock</h3>
          <p class="board-title">Board Member</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Free Resources ────────────────────────────────────────────── -->
  <section class="section" id="resources">
    <div class="container text-center">
      <h2 class="section-heading">🚀 Free Resources</h2>
      <p class="section-sub">Download these tools to start your journey today.</p>
      <div class="resources-grid grid-3">
        <a href="/downloads/vocational-training-resource-list.pdf" class="resource-card" download>
          <div class="resource-icon">📋</div>
          <p>Vocational Training Resource List Cheat Sheet</p>
        </a>
        <a href="/downloads/linkedin-profile-networking-checklist.pdf" class="resource-card" download>
          <div class="resource-icon">💼</div>
          <p>LinkedIn Profile &amp; Networking Checklist</p>
        </a>
        <a href="/downloads/chaos-to-calm-packet.pdf" class="resource-card" download>
          <div class="resource-icon">🌿</div>
          <p>Chaos to Calm Packet (Pranayama &amp; Yoga Sequences)</p>
        </a>
        <a href="/downloads/healthy-boundaries-cheat-sheet.pdf" class="resource-card" download>
          <div class="resource-icon">🛡️</div>
          <p>Healthy Boundaries Cheat Sheet</p>
        </a>
        <a href="/downloads/3-brains-in-real-life.pdf" class="resource-card" download>
          <div class="resource-icon">🧠</div>
          <p>The 3 Brains in Real Life</p>
        </a>
        <a href="/downloads/create-your-own-rebel-manifesto.pdf" class="resource-card" download>
          <div class="resource-icon">✊</div>
          <p>Create Your Own Rebel Manifesto</p>
        </a>
        <a href="/downloads/sober-rebel-playlist-reflection.pdf" class="resource-card" download>
          <div class="resource-icon">🎵</div>
          <p>Sober Rebel Playlist Reflection Exercise</p>
        </a>
        <a href="/downloads/yoga-sequences.pdf" class="resource-card" download>
          <div class="resource-icon">🧘</div>
          <p>Yoga Sequences</p>
        </a>
        <a href="/downloads/foam-roller-charts.pdf" class="resource-card" download>
          <div class="resource-icon">🏋️</div>
          <p>Foam Roller Charts</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Donation CTA ───────────────────────────────────────────────── -->
  <section class="section donation-cta bg-brand">
    <div class="container text-center">
      <h2>Support the Mission</h2>
      <p>Each Sober Rebel is sponsored by generous donations from people who believe in this cause.</p>
      <a href="/%F0%9F%92%9B-choose-your-impact" class="btn btn-white" style="margin-top: 1.5rem;">💛 Choose Your Impact</a>
    </div>
  </section>

</BaseLayout>

<style>
/* Hero */
.hero {
  background: linear-gradient(160deg, var(--color-brand-subtle) 0%, #fff 65%);
  padding-block: var(--space-16);
}
.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-12);
  align-items: center;
}
.hero-text h1 { font-size: var(--text-4xl); margin-bottom: var(--space-4); }
.hero-tagline { font-size: var(--text-lg); color: var(--color-text-light); margin-bottom: var(--space-6); }
.hero-links a { margin-bottom: var(--space-1); }

/* Mission */
.mission-statement { font-size: var(--text-xl); font-family: var(--font-heading); font-style: italic; margin: var(--space-6) auto; max-width: 680px; }
.mission-body { max-width: 620px; margin-inline: auto; color: var(--color-text-light); }

/* About Vanessa */
.about-vanessa { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-12); align-items: center; }
.about-vanessa h2 { font-size: var(--text-3xl); margin-bottom: var(--space-4); }
.about-vanessa p { color: var(--color-text-light); margin-bottom: var(--space-4); }
.about-portrait img { border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); }

/* Learn */
.learn-icon { font-size: 2.5rem; margin-bottom: var(--space-3); }
.learn-grid .card-body h3 { margin-bottom: var(--space-2); }

/* FAST */
.fast-grid { margin-top: var(--space-10); }
.fast-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  box-shadow: var(--shadow-md);
  text-align: center;
}
.fast-letter {
  font-family: var(--font-heading);
  font-size: var(--text-5xl);
  font-weight: 700;
  color: var(--color-brand);
  line-height: 1;
  margin-bottom: var(--space-3);
}
.fast-card h3 { font-size: var(--text-xl); margin-bottom: var(--space-2); }
.fast-card p { color: var(--color-text-light); font-size: var(--text-sm); }

/* Board */
.board-grid { display: flex; justify-content: center; gap: var(--space-10); flex-wrap: wrap; }
.board-member { text-align: center; }
.board-photo {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 auto var(--space-4);
  border: 3px solid var(--color-brand-light);
}
.board-photo img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
.board-member h3 { font-size: var(--text-lg); margin-bottom: var(--space-1); }
.board-title { color: var(--color-text-muted); font-size: var(--text-sm); }

/* Resources */
.resources-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); margin-top: var(--space-8); }
.resource-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-5);
  background: #fff;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  color: var(--color-text);
  text-decoration: none;
  border: 1px solid var(--color-brand-subtle);
  transition: all var(--transition);
  text-align: center;
  font-size: var(--text-sm);
}
.resource-card:hover { border-color: var(--color-brand); box-shadow: var(--shadow-md); transform: translateY(-2px); color: var(--color-brand-dark); }
.resource-icon { font-size: 1.75rem; }

/* Donation CTA */
.donation-cta { padding-block: var(--space-12); }
.donation-cta h2 { font-size: var(--text-3xl); color: #fff; margin-bottom: var(--space-4); }
.donation-cta p { color: rgba(255,255,255,0.85); font-size: var(--text-lg); max-width: 560px; margin-inline: auto; }

/* Responsive */
@media (max-width: 768px) {
  .hero-inner, .about-vanessa { grid-template-columns: 1fr; }
  .hero-text h1 { font-size: var(--text-3xl); }
  .hero-image { display: none; }
  .resources-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .resources-grid { grid-template-columns: 1fr; }
}
</style>
