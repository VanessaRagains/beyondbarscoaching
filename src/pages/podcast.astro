---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The Sober Rebel Club Podcast | Beyond BARS Coaching"
  description="Listen to The Sober Rebel Club Podcast hosted by Vanessa Ragains — conversations about sobriety, nervous-system health, and life beyond BARS."
>

  <section class="section-sm bg-soft text-center">
    <div class="container">
      <h1>🎙️ The Sober Rebel Club Podcast!</h1>
      <p class="page-sub">
        Conversations about sobriety, nervous-system health, and life beyond BARS.
        Hosted by Vanessa Ragains, AKA Coach Veeeee.
      </p>
      <a href="https://podcasts.apple.com/us/podcast/the-sober-rebel-podcast/id1881449538" target="_blank" rel="noopener" class="apple-badge">
        <img src="https://tools.applemediaservices.com/api/badges/listen-on-apple-podcasts/badge/en-us?size=250x83" alt="Listen on Apple Podcasts" height="40" />
      </a>
      <div class="divider"></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="embed-frame">
        <iframe
          height="550px"
          title="Sober Rebel Club Podcast"
          src="https://www.podbean.com/player-v2/?i=zgik7-14dd971-pbblog-playlist&share=1&download=1&rtl=0&fonts=Arial&skin=1&font-color=auto&logo_link=episode_page&order=episodic&limit=10&filter=all&ss=a713390a017602015775e868a2cf26b0&btn-skin=7&size=315"
        >
        </iframe>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-sub { color: var(--color-text-light); font-size: var(--text-lg); margin-top: var(--space-3); max-width: 600px; margin-inline: auto; }

.embed-placeholder {
  text-align: center;
  padding: var(--space-16);
  background: var(--color-bg-soft);
  border-radius: var(--radius-xl);
  border: 2px dashed var(--color-brand-light);
  max-width: 600px;
  margin-inline: auto;
}
.apple-badge { display: inline-block; margin-top: var(--space-4); }
.apple-badge img { height: 40px; width: auto; }
.embed-icon { font-size: 4rem; margin-bottom: var(--space-4); }
.embed-placeholder h2 { margin-bottom: var(--space-3); }
.embed-placeholder p { color: var(--color-text-light); }
</style>
