---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sober Rebel Playlist | Beyond BARS Coaching"
  description="Listen to the Sober Rebel Playlist curated by Vanessa Ragains — music for your recovery journey."
>

  <section class="section-sm bg-soft text-center">
    <div class="container">
      <h1>🎧 The Sober Rebel Playlist</h1>
      <p class="page-sub">Music to fuel your rebel journey.</p>
      <div class="divider"></div>
    </div>
  </section>

  <section class="section playlist">
    <div class="container">
      <iframe
        allow="autoplay *; encrypted-media *;"
        frameborder="0"
        height="450"
        title="Sober Rebel Club Playlist"
        style="width:100%;max-width:660px;overflow:hidden;background:transparent;"
        sandbox="allow-forms allow-popups allow-same-origin allow-scripts allow-storage-access-by-user-activation allow-top-navigation-by-user-activation"
        src="https://embed.music.apple.com/us/playlist/sober-rebel/pl.u-bYG7ty5zxaX"
      ></iframe>
    </div>
  </section>

</BaseLayout>

<style>
.page-sub { color: var(--color-text-light); font-size: var(--text-lg); margin-top: var(--space-3); }
.embed-icon { font-size: 4rem; margin-bottom: var(--space-4); }
.section.playlist .container { display: flex; justify-content: center; align-items: center; }
</style>
