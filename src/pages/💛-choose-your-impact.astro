---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Choose Your Impact | Beyond BARS Coaching"
  description="Support Beyond BARS Coaching by donating to one of our impact buckets — workbooks, career accelerator, Sober Rebel Club, or CREW partnership."
>

  <section class="section-sm bg-soft text-center">
    <div class="container">
      <h1>Choose Your Impact Bucket Below</h1>
      <p class="page-sub">
        Every donation transforms the life of a system-impacted woman choosing sobriety and stability.
      </p>
      <div class="divider"></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="impact-grid grid-4">

        <!-- Card 1: CREW Partnership -->
        <div class="impact-card card">
          <img src="/img/choose-your-impact/CREW.jpg" alt="Women welcoming someone home" class="impact-card-img" />
          <div class="card-body">
            <div class="impact-goal-wrap"><span class="impact-goal-label">Fundraising Goal</span><div class="impact-amount">$20K</div></div>
            <h2>Help me send 1000 workbooks to CREW!!!</h2>
            <p>
              CREW is an organization that meets women after being released from jail with a
              duffle bag full of clothes in their size and full-size amenities. Your generous
              donation gives them a hard copy of <em>Your First 90-Days Beyond BARS</em> workbook.
              Help us reach our goal of sending 1,000 workbooks!
            </p>
            <a href="https://givebutter.com/crew-partnership" target="_blank" rel="noopener" class="btn btn-primary">
              Fund Our CREW Partnership
            </a>
          </div>
        </div>

        <!-- Card 2: Career Accelerator -->
        <div class="impact-card card">
          <img src="/img/choose-your-impact/career-accelerator.jpg" alt="Resume tips notebook" class="impact-card-img" />
          <div class="card-body">
            <div class="impact-goal-wrap"><span class="impact-goal-label">Fundraising Goal</span><div class="impact-amount">$5K</div></div>
            <h2>Donate To Our Career Accelerator Fund</h2>
            <p>
              One of the biggest challenges women in transition face is career readiness. This
              6-week program complements our <em>6-Months Beyond BARS</em> Workbook (coming soon!).
              Your donation helps them learn how to build a resume and LinkedIn Profile so they can
              walk into any room ready to change their life.
            </p>
            <a
              href="https://givebutter.com/accelerator-program-fund"
              target="_blank"
              rel="noopener"
              class="btn btn-primary"
            >
              Fund Our Career Accelerator
            </a>
          </div>
        </div>

        <!-- Card 3: Sober Rebel Club -->
        <div class="impact-card card">
          <img src="/img/choose-your-impact/sober-rebel-club.png" alt="The Sober Rebel Club for Women" class="impact-card-img" />
          <div class="card-body">
            <div class="impact-goal-wrap"><span class="impact-goal-label">Fundraising Goal</span><div class="impact-amount">$15K</div></div>
            <h2>Fund The Sober Rebel Club for Women</h2>
            <p>
              The Sober Rebel Club is an alcohol-free community for system-impacted women
              choosing sobriety, nervous-system safety, movement, and real connection —
              online + IRL in the Bay Area. Your donation helps cover podcast hosting fees,
              in-person meeting costs, tech for online gatherings, and SAFE transportation
              to and from our activities.
            </p>
            <a
              href="https://givebutter.com/SoberRebelClub"
              target="_blank"
              rel="noopener"
              class="btn btn-primary"
            >
              Fund The Sober Rebel Club
            </a>
          </div>
        </div>

        <!-- Card 4: Workbooks -->
        <div class="impact-card card">
          <img src="/img/choose-your-impact/workbook.jpg" alt="Woman planning at a vision board" class="impact-card-img" />
          <div class="card-body">
            <div class="impact-goal-wrap"><span class="impact-goal-label">Cost Per Book</span><div class="impact-amount">$20<span>/book</span></div></div>
            <h2>Help Keep Workbook In Stock for In-Person Cohorts</h2>
            <p>Clients love these workbooks! Typical groups are 10–20 people per cohort.</p>
            <blockquote class="testimonial">
              "Would recommend this workbook to anyone new to their recovery journey."
            </blockquote>
            <blockquote class="testimonial">
              "I learned that I'm not alone in the way that I think and feel."
            </blockquote>
            <a
              href="https://givebutter.com/SponsorARebel"
              target="_blank"
              rel="noopener"
              class="btn btn-primary"
            >
              Fund Keeping Our Workbook In Stock
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Tech & Operations — smaller donation option -->
  <section class="section bg-soft">
    <div class="container text-center">
      <div class="tech-card card">
          <img src="/img/choose-your-impact/tech-ops.jpg" alt="Colorful abstract representing connection and technology" class="impact-card-img" />
        <div class="card-body">
          <div class="impact-goal-wrap"><span class="impact-goal-label">Monthly Goal</span><div class="impact-amount">$500–$1K<span>/mo</span></div></div>
          <h2>Help Fund Our Monthly Tech and Operations</h2>
          <p>
            I rely on tech to help me stay on top of my work, relationships, while making an
            impact in the lives of the people I serve. Your donation helps keep all systems moving
            and gives us wiggle room for the unexpected expenses that come with running a nonprofit!
          </p>
          <a href="https://givebutter.com/BBC-monthly" target="_blank" rel="noopener" class="btn btn-primary">
            Fund Our Tech + Daily Operations
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-sm text-center">
    <div class="container">
      <h2 class="section-heading">💛 General Donation</h2>
      <p style="color: var(--color-text-light); max-width: 560px; margin-inline: auto; margin-bottom: var(--space-6);">
        Not sure which bucket to choose? Any amount makes a difference.
      </p>
      <a href="https://givebutter.com/beyond-bars-coaching" target="_blank" rel="noopener" class="btn btn-primary">💛 Donate</a>
    </div>
  </section>

  <section class="section-sm bg-soft text-center">
    <div class="container">
      <p style="color: var(--color-text-light); max-width: 560px; margin-inline: auto; font-size: var(--text-lg);">
        For questions about donations, email
        <a href="mailto:vanessa.ragains@gmail.com">Vanessa.Ragains@gmail.com</a>.
        Thank you for your generous donations!
      </p>
    </div>
  </section>

</BaseLayout>

<style>
.page-sub { color: var(--color-text-light); font-size: var(--text-lg); margin-top: var(--space-3); max-width: 560px; margin-inline: auto; }

.impact-card-img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  display: block;
}
.impact-card-img--contain {
  object-fit: contain;
  background: #1a2e1a;
}
.tech-card .impact-card-img {
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  height: 220px;
}

.impact-grid { align-items: stretch; }
.impact-card { height: 100%; display: flex; flex-direction: column; }
.impact-card .card-body { flex: 1; display: flex; flex-direction: column; }
.impact-card p { color: var(--color-text-light); flex: 1; margin-bottom: var(--space-4); }
.impact-card h2 { font-size: var(--text-xl); margin-bottom: var(--space-3); }
.impact-card .btn { margin-top: auto; }

.tech-card { max-width: 560px; margin-inline: auto; }
.tech-card .card-body { display: flex; flex-direction: column; align-items: center; text-align: center; }
.tech-card p { color: var(--color-text-light); margin-bottom: var(--space-4); }
.tech-card h2 { font-size: var(--text-xl); margin-bottom: var(--space-3); }

.impact-goal-wrap { margin-bottom: var(--space-3); }
.impact-goal-label {
  display: block;
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-teal);
  margin-bottom: var(--space-1);
}

.impact-amount {
  font-family: var(--font-heading);
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--color-gold-dark);
  line-height: 1;
}
.impact-amount span { font-size: var(--text-lg); color: var(--color-text-muted); }

.testimonial {
  border-left: 3px solid var(--color-brand-light);
  padding-left: var(--space-3);
  color: var(--color-text-muted);
  font-style: italic;
  font-size: var(--text-sm);
  margin-bottom: var(--space-3);
}

.coming-soon-note {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: var(--space-2);
  text-align: center;
  flex: unset !important;
}
</style>
