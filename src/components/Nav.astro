---
const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');
---

<nav class="nav">
  <div class="nav-inner container">
    <a href="/about" class="nav-logo" aria-label="Beyond BARS Coaching — Home">
      <img src="/img/logo.png" alt="Beyond BARS Coaching" height="60" />
    </a>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-menu" id="nav-menu" role="list">
      <li>
        <a href="/about" class:list={['nav-link', { active: isActive('/about') }]}>About</a>
      </li>

      <li class="nav-dropdown">
        <button class="nav-link nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
          Work With Me <span class="nav-caret" aria-hidden="true">▾</span>
        </button>
        <ul class="nav-dropdown-menu" role="list">
          <li><a href="/program-details">Program Details</a></li>
          <li><a href="https://www.skool.com/the-sober-rebel-club-6262/about" target="_blank" rel="noopener">Sober Rebel Club</a></li>
          <li><a href="/about#resources">Free Resources</a></li>
          <li><a href="/book-a-call">Book A Call</a></li>
        </ul>
      </li>

      <li>
        <a href="/podcast" class:list={['nav-link', { active: isActive('/podcast') }]}>Podcast</a>
      </li>

      <li>
        <a href="/blog" class:list={['nav-link', { active: isActive('/blog') }]}>Blog</a>
      </li>

      <li>
        <a href="/playlist" class:list={['nav-link', { active: isActive('/playlist') }]}>Playlist</a>
      </li>

      <li class="nav-dropdown">
        <button class="nav-link nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
          More <span class="nav-caret" aria-hidden="true">▾</span>
        </button>
        <ul class="nav-dropdown-menu" role="list">
          <li><a href="/beyond-bars-program#faq">FAQs</a></li>
          <li><a href="https://g.page/r/CQObw53DEI7TEBI/review" target="_blank" rel="noopener">Reviews</a></li>
        </ul>
      </li>

      <li>
        <a href="/%F0%9F%92%9B-choose-your-impact" class="nav-link nav-cta">💛 Choose Your Impact</a>
      </li>
    </ul>
  </div>
</nav>

<style>
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--color-nav-bg);
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  height: 72px;
}

.nav-logo img { height: 52px; width: auto; }

.nav-menu {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  list-style: none;
  margin-left: auto;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0.4rem 0.75rem;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--color-text);
  background: none;
  border: none;
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: color var(--transition), background var(--transition);
  white-space: nowrap;
}
.nav-link:hover, .nav-link.active { color: var(--color-brand); }
.nav-caret { font-size: 0.6em; transition: transform var(--transition); }

.nav-cta {
  background: var(--color-brand);
  color: #fff !important;
  border-radius: var(--radius-full);
  padding: 0.4rem 1rem;
}
.nav-cta:hover { background: var(--color-brand-dark); }

/* Dropdowns */
.nav-dropdown { position: relative; }
.nav-dropdown-menu {
  display: none;
  position: absolute;
  top: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  min-width: 180px;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  list-style: none;
  padding: var(--space-2) 0;
  z-index: 200;
}
.nav-dropdown-menu li a {
  display: block;
  padding: 0.5rem 1rem;
  font-size: var(--text-sm);
  color: var(--color-text);
  white-space: nowrap;
}
.nav-dropdown-menu li a:hover { color: var(--color-brand); background: var(--color-bg-soft); }
.nav-dropdown.open .nav-dropdown-menu { display: block; }
.nav-dropdown.open .nav-caret { transform: rotate(180deg); }

/* Hamburger */
.nav-toggle {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  margin-left: auto;
}
.nav-toggle span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--color-text);
  border-radius: 2px;
  transition: all var(--transition);
}

@media (max-width: 900px) {
  .nav-toggle { display: flex; }
  .nav-menu {
    display: none;
    position: absolute;
    top: 72px;
    left: 0;
    right: 0;
    background: #fff;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding: var(--space-4) 0;
    box-shadow: var(--shadow-lg);
    border-top: 1px solid var(--color-bg-section);
  }
  .nav-menu.open { display: flex; }
  .nav-link { border-radius: 0; padding: 0.75rem var(--space-6); }
  .nav-cta { margin: var(--space-2) var(--space-6); border-radius: var(--radius-full); }
  .nav-dropdown-menu {
    position: static;
    transform: none;
    box-shadow: none;
    background: var(--color-bg-soft);
    border-radius: 0;
  }
}
</style>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const menu   = document.querySelector('.nav-menu') as HTMLElement;

  toggle?.addEventListener('click', () => {
    const open = menu.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });

  document.querySelectorAll('.nav-dropdown-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('.nav-dropdown') as HTMLElement;
      const open   = parent.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
  });

  // Close dropdowns on outside click
  document.addEventListener('click', (e) => {
    document.querySelectorAll('.nav-dropdown.open').forEach((el) => {
      if (!el.contains(e.target as Node)) {
        el.classList.remove('open');
        const btn = el.querySelector('.nav-dropdown-toggle') as HTMLElement;
        btn?.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>
