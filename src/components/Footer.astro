    </div>

    <div class="footer-bottom">
      <p>Copyright &copy; {new Date().getFullYear()} BeyondBARSCoaching.org — All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--color-footer-bg);
  color: var(--color-footer-text);
  padding-block: var(--space-12) var(--space-8);
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: var(--space-8);
}

.footer-logo-link img { height: 52px; width: 52px; }

.footer-tagline {
  margin-top: var(--space-4);
  font-size: var(--text-sm);
  color: var(--color-footer-muted);
  line-height: 1.6;
  max-width: 280px;
}

.footer-org {
  margin-top: var(--space-3);
  font-size: var(--text-xs);
  color: var(--color-footer-muted);
}

.footer-social {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-4);
}
.footer-social a {
  color: var(--color-footer-muted);
  transition: color var(--transition);
}
.footer-social a:hover { color: var(--color-brand-light); }

.footer-nav h4, .footer-contact h4 {
  font-family: var(--font-heading);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-footer-text);
  margin-bottom: var(--space-4);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.footer-nav ul { list-style: none; }
.footer-nav li { margin-bottom: var(--space-2); }
.footer-nav a, .footer-contact a {
  color: var(--color-footer-muted);
  font-size: var(--text-sm);
  transition: color var(--transition);
}
.footer-nav a:hover, .footer-contact a:hover { color: var(--color-brand-light); }

.footer-contact p { margin-bottom: var(--space-2); }

.footer-bottom {
  margin-top: var(--space-8);
  padding-top: var(--space-6);
  border-top: 1px solid rgba(255,255,255,0.08);
  text-align: center;
  font-size: var(--text-xs);
  color: var(--color-footer-muted);
}

@media (max-width: 900px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 560px) {
  .footer-grid { grid-template-columns: 1fr; }
}
</style>
