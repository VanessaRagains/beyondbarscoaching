          <li><a href="/about">About</a></li>
          <li><a href="/program-details">Program Details</a></li>
          <li><a href="/book-a-call">Book A Call</a></li>
          <li><a href="/podcast">Podcast</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/playlist">Playlist</a></li>
        </ul>
      </div>

      <div class="footer-nav">
        <h4>More</h4>
        <ul>
          <li><a href="/%F0%9F%92%9B-choose-your-impact">💛 Choose Your Impact</a></li>
          <li><a href="https://g.page/r/CQObw53DEI7TEBI/review" target="_blank" rel="noopener">Reviews</a></li>
          <li><a href="/beyond-bars-program#faq">FAQs</a></li>
          <li><a href="/privacy-statement">Privacy Statement</a></li>
          <li><a href="/terms-%26-conditions-1">Terms &amp; Conditions</a></li>
        </ul>
      </div>

      <div class="footer-contact">
        <h4>Contact</h4>
        <p><a href="sms:+16503076592">Text (650) 307-6592</a></p>
        <p><a href="mailto:Vanessa.Ragains@gmail.com">Vanessa.Ragains@gmail.com</a></p>
