        <h4>Navigate</h4>
        <ul>
          <li><a href={`${base}program-details`}>Program Details</a></li>
          <li><a href={`${base}book-a-call`}>Book A Call</a></li>
          <li><a href={`${base}podcast`}>Podcast</a></li>
          <li><a href={`${base}blog`}>Blog</a></li>
          <li><a href={`${base}playlist`}>Playlist</a></li>
        </ul>
      </div>

      <div class="footer-nav">
        <h4>More</h4>
        <ul>
          <li><a href={`${base}%F0%9F%92%9B-choose-your-impact`}>💛 Choose Your Impact</a></li>
          <li><a href="https://g.page/r/CQObw53DEI7TEBI/review" target="_blank" rel="noopener">Reviews</a></li>
          <li><a href={`${base}beyond-bars-program#faq`}>FAQs</a></li>
          <li><a href={`${base}privacy-statement`}>Privacy Statement</a></li>
          <li><a href={`${base}terms-%26-conditions-1`}>Terms &amp; Conditions</a></li>
        </ul>
      </div>

      <div class="footer-contact">
        <h4>Contact</h4>
        <p><a href="sms:+16503076592">Text (650) 307-6592</a></p>
        <p><a href="mailto:Vanessa.Ragains@gmail.com">Vanessa.Ragains@gmail.com</a></p>
        <a href="https://givebutter.com/beyond-bars-coaching" target="_blank" rel="noopener" class="footer-donate-btn">💛 Donate</a>
